# 默认 profile（推荐）
MYSQL_PROFILE=main

# SQL 规则配置（留空则走默认规则）
# 允许的语句起始关键词（逗号分隔）
MYSQL_SQL_ALLOWED_START=select,show,desc,describe,explain,with
# 禁止的关键词（逗号分隔）
MYSQL_SQL_FORBIDDEN_KEYWORDS=delete,insert,update,replace,truncate,drop,alter,create,grant,revoke,rename,merge,call
# 禁止的短语（逗号分隔）
MYSQL_SQL_FORBIDDEN_PHRASES=into_outfile,into_dumpfile,load_data,lock_tables,unlock_tables

# 多库 profile 示例：main
MYSQL_HOST_main=
MYSQL_PORT_main=
MYSQL_USER_main=rsync
MYSQL_PASSWORD_main=your_password
# 支持单库或多库（逗号分隔）；配置多个库时，调用脚本需通过 --database 指定目标库
MYSQL_DATABASE_main=rsync,main_db,analytics
MYSQL_TIMEOUT_main=15
# MYSQL_SOCKET_main=/var/run/mysqld/mysqld.sock

# 多库 profile 示例：reporting
MYSQL_HOST_reporting=
MYSQL_PORT_reporting=
MYSQL_USER_reporting=report_user
MYSQL_PASSWORD_reporting=report_password
MYSQL_DATABASE_reporting=report_db
MYSQL_TIMEOUT_reporting=15
# MYSQL_SOCKET_reporting=/var/run/mysqld/mysqld.sock
